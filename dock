#!/bin/bash
# =============================================================================
# dock - Dockerized Laravel CLI
# =============================================================================
# Unified command-line interface for managing dockerized Laravel applications.
#
# Usage: ./dock <command> [options]
#
# Commands:
#   start       Start the application containers
#   stop        Stop all containers
#   restart     Restart all containers
#   status      Show container status
#   logs        View container logs
#   shell       Open a shell in a container
#   exec        Execute a command in the app container
#   artisan     Run Laravel Artisan commands
#   composer    Run Composer commands
#   npm         Run NPM commands
#   tinker      Start Laravel Tinker
#   migrate     Run database migrations
#   fresh       Fresh migrate with seed
#   deploy      Deploy to production
#   install     Install dockerized-laravel in a project
#   help        Show help
#
# =============================================================================

set -e

# Determine script location and project root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Handle both direct execution and symlink scenarios
if [[ -d "${SCRIPT_DIR}/scripts/lib" ]]; then
    PROJECT_ROOT="$SCRIPT_DIR"
    SCRIPT_LIB_DIR="${SCRIPT_DIR}/scripts/lib"
elif [[ -d "${SCRIPT_DIR}/lib" ]]; then
    PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
    SCRIPT_LIB_DIR="${SCRIPT_DIR}/lib"
else
    # Assume we're in project root
    PROJECT_ROOT="$SCRIPT_DIR"
    SCRIPT_LIB_DIR="${SCRIPT_DIR}/scripts/lib"
fi

export SCRIPT_LIB_DIR
export PROJECT_ROOT

# Source library files
source "${SCRIPT_LIB_DIR}/colors.sh"
source "${SCRIPT_LIB_DIR}/utils.sh"
source "${SCRIPT_LIB_DIR}/env.sh"
source "${SCRIPT_LIB_DIR}/checks.sh"
source "${SCRIPT_LIB_DIR}/docker.sh"

# -----------------------------------------------------------------------------
# Global Options
# -----------------------------------------------------------------------------
VERBOSE=false
QUIET=false
DEBUG=false
ENV_FILE=".env"
COMMAND=""
ARGS=()

# -----------------------------------------------------------------------------
# Version
# -----------------------------------------------------------------------------
VERSION="2.0.0"

# -----------------------------------------------------------------------------
# Help Text
# -----------------------------------------------------------------------------
show_help() {
    echo ""
    echo -e "${BOLD}${ICON_DOCKER} Dockerized Laravel CLI${NC} v${VERSION}"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo "    ./dock <command> [options] [arguments]"
    echo ""
    echo -e "${BOLD}COMMANDS${NC}"
    echo -e "    ${GREEN}start${NC}               Start the application containers"
    echo -e "    ${GREEN}stop${NC}                Stop all containers"
    echo -e "    ${GREEN}restart${NC}             Restart all containers"
    echo -e "    ${GREEN}status${NC}              Show container status"
    echo -e "    ${GREEN}logs${NC} [service]      View container logs (-f to follow)"
    echo -e "    ${GREEN}shell${NC} [container]   Open a shell in a container (default: app)"
    echo -e "    ${GREEN}exec${NC} <cmd>          Execute a command in the app container"
    echo ""
    echo -e "    ${CYAN}artisan${NC} <cmd>        Run Laravel Artisan command"
    echo -e "    ${CYAN}composer${NC} <cmd>       Run Composer command"
    echo -e "    ${CYAN}npm${NC} <cmd>            Run NPM command"
    echo -e "    ${CYAN}tinker${NC}               Start Laravel Tinker REPL"
    echo -e "    ${CYAN}migrate${NC}              Run database migrations"
    echo -e "    ${CYAN}fresh${NC}                Fresh migrate with seed"
    echo -e "    ${CYAN}seed${NC}                 Run database seeders"
    echo ""
    echo -e "    ${YELLOW}deploy${NC} <env-file>   Deploy to production server"
    echo -e "    ${YELLOW}install${NC}             Install dockerized-laravel in a project"
    echo ""
    echo -e "    ${DIM}help${NC}                Show this help message"
    echo -e "    ${DIM}version${NC}             Show version"
    echo ""
    echo -e "${BOLD}OPTIONS${NC}"
    echo "    -v, --verbose       Show detailed output"
    echo "    -q, --quiet         Suppress non-essential output"
    echo "    -e, --env <file>    Use a specific .env file"
    echo "    -h, --help          Show help for a command"
    echo "    --debug             Show debug information"
    echo ""
    echo -e "${BOLD}EXAMPLES${NC}"
    echo "    ./dock start                    # Start containers"
    echo "    ./dock start --verbose          # Start with detailed output"
    echo "    ./dock logs -f                  # Follow all logs"
    echo "    ./dock logs app                 # View app container logs"
    echo "    ./dock artisan migrate          # Run migrations"
    echo "    ./dock shell                    # Enter app container shell"
    echo "    ./dock shell mariadb            # Enter database container"
    echo ""
    echo -e "${BOLD}ENVIRONMENT${NC}"
    echo "    Configure via .env file:"
    echo -e "    - ${BLUE}SERVER${NC}      Server type: artisan, octane, fpm, nginx, caddy"
    echo -e "    - ${BLUE}SERVICES${NC}    Additional services: redis,mailpit,meilisearch"
    echo -e "    - ${BLUE}APP_ENV${NC}     Environment: local, staging, production"
    echo ""
}

show_command_help() {
    local cmd="$1"
    
    case "$cmd" in
        start)
            echo ""
            echo -e "${BOLD}dock start${NC} - Start application containers"
            echo ""
            echo -e "${BOLD}USAGE${NC}"
            echo "    ./dock start [options]"
            echo ""
            echo -e "${BOLD}OPTIONS${NC}"
            echo "    --build         Force rebuild containers"
            echo "    --no-cache      Build without using cache"
            echo "    -v, --verbose   Show detailed output"
            echo "    -q, --quiet     Suppress output"
            echo ""
            echo -e "${BOLD}DESCRIPTION${NC}"
            echo "    Starts all configured containers based on your .env settings."
            echo "    Automatically handles Octane setup if SERVER=octane."
            echo ""
            ;;
        stop)
            echo ""
            echo -e "${BOLD}dock stop${NC} - Stop application containers"
            echo ""
            echo -e "${BOLD}USAGE${NC}"
            echo "    ./dock stop [options]"
            echo ""
            echo -e "${BOLD}OPTIONS${NC}"
            echo "    -v, --verbose   Show detailed output"
            echo "    -q, --quiet     Suppress output"
            echo ""
            echo -e "${BOLD}DESCRIPTION${NC}"
            echo "    Stops and removes all containers for the current project."
            echo "    Volumes are preserved by default."
            echo ""
            ;;
        logs)
            echo ""
            echo -e "${BOLD}dock logs${NC} - View container logs"
            echo ""
            echo -e "${BOLD}USAGE${NC}"
            echo "    ./dock logs [service] [options]"
            echo ""
            echo -e "${BOLD}OPTIONS${NC}"
            echo "    -f, --follow    Follow log output"
            echo "    -n, --tail <N>  Number of lines to show (default: 100)"
            echo ""
            echo -e "${BOLD}EXAMPLES${NC}"
            echo "    ./dock logs              # All container logs"
            echo "    ./dock logs app          # Only app container"
            echo "    ./dock logs -f           # Follow all logs"
            echo "    ./dock logs app -f -n 50 # Follow app logs, last 50 lines"
            echo ""
            ;;
        deploy)
            echo ""
            echo -e "${BOLD}dock deploy${NC} - Deploy to production"
            echo ""
            echo -e "${BOLD}USAGE${NC}"
            echo "    ./dock deploy <env-file>"
            echo ""
            echo -e "${BOLD}ARGUMENTS${NC}"
            echo "    env-file    Path to the production .env file"
            echo ""
            echo -e "${BOLD}DESCRIPTION${NC}"
            echo "    Deploys the application to a production server."
            echo "    Requires REPO_URL, BRANCH, and DEPLOY_DIR in the env file."
            echo ""
            echo -e "${BOLD}EXAMPLE${NC}"
            echo "    ./dock deploy /path/to/production.env"
            echo ""
            ;;
        *)
            show_help
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Command: start
# -----------------------------------------------------------------------------
cmd_start() {
    local build=false
    local no_cache=false
    
    # Parse command-specific options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --build)    build=true; shift ;;
            --no-cache) no_cache=true; shift ;;
            -h|--help)  show_command_help start; return 0 ;;
            *)          shift ;;
        esac
    done
    
    print_header "Dockerized Laravel"
    
    # Load and validate environment
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    validate_full_env "start" || return 1
    
    # Run pre-flight checks
    run_preflight_checks "start" "$PROJECT_ROOT" || return 1
    
    # Print configuration
    print_env_summary
    
    # Start containers
    print_section "${ICON_PACKAGE} Starting Containers"
    
    local exit_code=0
    if [[ "${VERBOSE:-false}" == "true" ]]; then
        # In verbose mode, show all output directly
        print_info "Starting containers..."
        docker_up "$build" || exit_code=$?
    else
        # In normal mode, show progress inline
        echo -ne "  ${ICON_BULLET} Building and starting containers..."
        docker_up "$build" > /dev/null 2>&1 || exit_code=$?
        if [[ $exit_code -eq 0 ]]; then
            echo -e " ${GREEN}${ICON_SUCCESS}${NC}"
        else
            echo -e " ${RED}${ICON_ERROR}${NC}"
        fi
    fi
    
    if [[ $exit_code -ne 0 ]]; then
        print_error "Failed to start containers"
        return 1
    fi
    
    print_success "Containers started"
    
    # Give containers a moment to initialize
    sleep 2
    
    # Print status (ignore errors - containers might not be labeled yet)
    print_container_status || true
    
    # Handle server-specific setup
    if [[ "${SERVER:-artisan}" == "octane" ]]; then
        setup_octane || true
    fi
    
    # Standard provisioning
    provision_app || true
    
    # Handle artisan serve mode (interactive)
    if [[ "${SERVER:-artisan}" == "artisan" ]]; then
        print_ready "http://localhost:${APP_PORT:-8000}"
        print_info "Starting artisan serve (Ctrl+C to stop)..."
        docker exec -it "${CONTAINER_NAME}" php artisan serve --host=0.0.0.0 --port=80
    else
        print_ready "http://localhost:${APP_PORT:-8000}"
    fi
}

# Setup Octane server
setup_octane() {
    print_verbose "Setting up Octane..."
    
    # Check if Octane is installed
    if ! check_octane_installed; then
        print_info "Installing Laravel Octane..."
        docker exec "${CONTAINER_NAME}" composer require laravel/octane 2>/dev/null
        docker exec "${CONTAINER_NAME}" php artisan octane:install --server=frankenphp -q 2>/dev/null
    fi
    
    # Link FrankenPHP binary
    print_verbose "Linking FrankenPHP binary..."
    docker exec "${CONTAINER_NAME}" mkdir -p vendor/laravel/octane/bin 2>/dev/null
    docker exec "${CONTAINER_NAME}" ln -sf /usr/local/bin/frankenphp vendor/laravel/octane/bin/frankenphp-linux-x86_64 2>/dev/null
    docker exec "${CONTAINER_NAME}" ln -sf /usr/local/bin/frankenphp vendor/laravel/octane/bin/frankenphp-linux-aarch64 2>/dev/null
    
    # Restart octane service
    docker exec "${CONTAINER_NAME}" supervisorctl -c /etc/supervisor/conf.d/00-base.conf restart octane 2>/dev/null || true
}

# Provision the application
provision_app() {
    print_verbose "Provisioning application..."
    
    # Create directories
    docker exec "${CONTAINER_NAME}" mkdir -p storage/framework/sessions storage/framework/views storage/framework/cache storage/app/public 2>/dev/null || true
    
    # Set permissions
    docker exec "${CONTAINER_NAME}" chmod -R 775 storage bootstrap/cache public 2>/dev/null || true
    docker exec "${CONTAINER_NAME}" setfacl -R -d -m u::rwX,g::rwX,o::rX storage/app/public/ 2>/dev/null || true
    docker exec "${CONTAINER_NAME}" setfacl -R -d -m u::rwX,g::rwX,o::rX public/ 2>/dev/null || true
    
    # Generate key only in local (.env is writable). Prod handles this in deploy.
    if is_local_env && [[ -z "${APP_KEY:-}" ]]; then
        print_verbose "Generating application key..."
        docker exec "${CONTAINER_NAME}" php artisan key:generate 2>/dev/null || true
    fi

    # Storage link
    docker exec "${CONTAINER_NAME}" php artisan storage:link --force 2>/dev/null || true

    # Clear caches in local env
    if is_local_env; then
        print_verbose "Clearing caches for local development..."
        docker exec "${CONTAINER_NAME}" php artisan optimize:clear 2>/dev/null || true
    fi
}

# -----------------------------------------------------------------------------
# Command: stop
# -----------------------------------------------------------------------------
cmd_stop() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) show_command_help stop; return 0 ;;
            *) shift ;;
        esac
    done
    
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    
    print_info "Stopping containers..."
    docker_down || true
    print_success "Containers stopped"
}

# -----------------------------------------------------------------------------
# Command: restart
# -----------------------------------------------------------------------------
cmd_restart() {
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    
    print_info "Restarting containers..."
    docker_restart || true
    print_success "Containers restarted"
}

# -----------------------------------------------------------------------------
# Command: status
# -----------------------------------------------------------------------------
cmd_status() {
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    
    print_header "Container Status"
    print_container_status
    
    print_nl
    print_section "${ICON_INFO} Details"
    docker_status
}

# -----------------------------------------------------------------------------
# Command: logs
# -----------------------------------------------------------------------------
cmd_logs() {
    local service=""
    local follow=false
    local tail=100
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--follow) follow=true; shift ;;
            -n|--tail)   tail="$2"; shift 2 ;;
            -h|--help)   show_command_help logs; return 0 ;;
            -*)          shift ;;
            *)           service="$1"; shift ;;
        esac
    done
    
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    docker_logs "$service" "$follow" "$tail"
}

# -----------------------------------------------------------------------------
# Command: shell
# -----------------------------------------------------------------------------
cmd_shell() {
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    
    local container="${1:-${CONTAINER_NAME}}"
    
    # Handle container name shortcuts
    if [[ -n "$1" ]] && [[ "$1" != "${CONTAINER_NAME}" ]] && [[ "$1" != "${CONTAINER_NAME}-"* ]]; then
        container="${CONTAINER_NAME}-${1}"
    fi
    
    print_info "Opening shell in ${container}..."
    docker exec -it "$container" bash || docker exec -it "$container" sh
}

