# -----------------------------------------------------------------------------
# Command: deploy
# -----------------------------------------------------------------------------
cmd_deploy() {
    local skip_confirm=false
    local skip_pull=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -y|--yes)     skip_confirm=true; shift ;;
            --skip-pull)  skip_pull=true; shift ;;
            -h|--help)    show_command_help deploy; return 0 ;;
            *)            shift ;;
        esac
    done

    print_header "Deployment"

    # Must run from inside a cloned repo with a .env present
    if [[ ! -d "${PROJECT_ROOT}/.git" ]]; then
        print_error "Not a git repository: ${PROJECT_ROOT}"
        print_info "First-time setup: clone your app repo to the server, then run this from inside it."
        return 1
    fi
    if [[ ! -f "${PROJECT_ROOT}/.env" ]]; then
        print_error ".env not found in ${PROJECT_ROOT}"
        print_info "Copy your production .env into this directory before deploying."
        return 1
    fi

    load_env "${PROJECT_ROOT}/.env" || return 1
    validate_full_env "deploy" || return 1

    cd "$PROJECT_ROOT" || return 1

    if [[ "${APP_ENV:-local}" == "local" ]]; then
        print_warning "APP_ENV=local — deploy is intended for staging/production."
        confirm "Continue anyway?" || return 1
    fi

    # Refuse running deploy from paths we shouldn't touch
    case "${PROJECT_ROOT}" in
        "/"|"/root"|"/etc"|"/usr"|"/var"|"/bin"|"/sbin"|"/boot")
            print_error "Refusing to deploy from unsafe path: '${PROJECT_ROOT}'"
            return 1
            ;;
    esac

    # ---- Fetch + summary ----------------------------------------------------
    local branch="${BRANCH:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo main)}"
    local current_sha new_sha
    current_sha=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")

    if [[ "$skip_pull" != "true" ]]; then
        print_info "Fetching origin..."
        if ! git fetch --tags origin "$branch" 2>&1 | grep -v "^$" >&2; then
            print_error "git fetch failed (check SSH key / token for the repo)"
            return 1
        fi
        new_sha=$(git rev-parse --short "origin/${branch}" 2>/dev/null || echo "$current_sha")
    else
        new_sha="$current_sha"
    fi

    if [[ -n "$(git status --porcelain 2>/dev/null | grep -v '^?? ')" ]]; then
        print_warning "Uncommitted local changes detected. Pull will use --autostash."
    fi

    print_section "${ICON_GEAR} Configuration"
    print_kv "App"          "${APP_NAME:-${CONTAINER_NAME}}"
    print_kv "Environment"  "${APP_ENV}"
    print_kv "Server"       "${SERVER:-octane}"
    print_kv "Branch"       "${branch}"
    print_kv "Domain"       "${DOMAIN:-localhost}"
    print_kv "Deploy path"  "${PROJECT_ROOT}"
    print_kv "Storage path" "${STORAGE_MOUNT_PATH:-${PROJECT_ROOT}/storage}"
    print_kv "DB data path" "${DB_MOUNT_PATH:-${PROJECT_ROOT}/db-data}"

    print_section "${ICON_PACKAGE} Changes"
    if [[ "$current_sha" == "$new_sha" ]]; then
        print_info "Already at ${current_sha} — no new commits."
        print_info "(re-deploy will still rebuild image and rerun migrations)"
    else
        print_kv "From" "$current_sha"
        print_kv "To"   "$new_sha"
        local commit_count
        commit_count=$(git rev-list --count "${current_sha}..${new_sha}" 2>/dev/null || echo "?")
        print_kv "Commits" "${commit_count}"
        echo ""
        git log --no-merges --pretty="  ${YELLOW}%h${NC} %s ${DIM}(%an)${NC}" \
            "${current_sha}..${new_sha}" 2>/dev/null | head -15 || true
        if [[ "$commit_count" =~ ^[0-9]+$ ]] && (( commit_count > 15 )); then
            echo -e "  ${DIM}... and $((commit_count - 15)) more${NC}"
        fi
        echo ""
        local file_count
        file_count=$(git diff --name-only "${current_sha}..${new_sha}" 2>/dev/null | wc -l | tr -d ' ')
        print_kv "Files changed" "${file_count}"
    fi

    print_nl
    if [[ "$skip_confirm" != "true" ]]; then
        confirm "Proceed with deployment?" || return 1
    fi

    # ---- Pull ---------------------------------------------------------------
    print_section "${ICON_PACKAGE} Deploying"

    if [[ "$skip_pull" != "true" && "$current_sha" != "$new_sha" ]]; then
        print_info "Pulling ${branch}..."
        git pull --rebase --autostash origin "$branch" 2>&1 | grep -v "^$" || true
        if [[ ${PIPESTATUS[0]} -ne 0 ]]; then
            print_error "git pull failed - resolve conflicts and re-run"
            return 1
        fi
        print_success "Pulled to $(git rev-parse --short HEAD)"
    fi

    # ---- Ensure mount paths + UID/GID ---------------------------------------
    # Container must never run as UID 0. If host user is root (e.g. deploy on a
    # bare VPS with no separate deploy user), fall back to 1000:1000 and chown
    # storage to that UID so the container can write to it.
    local host_uid="${USER_ID:-$(id -u)}"
    local host_gid="${GROUP_ID:-$(id -g)}"
    if [[ "$host_uid" == "0" ]]; then
        print_warning "Running as root - using UID/GID 1000 for the container user"
        print_info "    (run deploy as a non-root user to map host = container UID)"
        host_uid=1000
        host_gid=1000
    fi
    local storage_path="${STORAGE_MOUNT_PATH:-${PROJECT_ROOT}/storage}"
    local db_path="${DB_MOUNT_PATH:-${PROJECT_ROOT}/db-data}"

    mkdir -p "$storage_path" "$db_path"

    # Write/replace USER_ID and GROUP_ID in .env so rebuilds match this run
    if grep -qE '^USER_ID=' "${PROJECT_ROOT}/.env"; then
        if [[ "$(uname)" == "Darwin" ]]; then
            sed -i '' "s|^USER_ID=.*|USER_ID=${host_uid}|" "${PROJECT_ROOT}/.env"
        else
            sed -i "s|^USER_ID=.*|USER_ID=${host_uid}|" "${PROJECT_ROOT}/.env"
        fi
    else
        echo "USER_ID=${host_uid}" >> "${PROJECT_ROOT}/.env"
    fi
    if grep -qE '^GROUP_ID=' "${PROJECT_ROOT}/.env"; then
        if [[ "$(uname)" == "Darwin" ]]; then
            sed -i '' "s|^GROUP_ID=.*|GROUP_ID=${host_gid}|" "${PROJECT_ROOT}/.env"
        else
            sed -i "s|^GROUP_ID=.*|GROUP_ID=${host_gid}|" "${PROJECT_ROOT}/.env"
        fi
    else
        echo "GROUP_ID=${host_gid}" >> "${PROJECT_ROOT}/.env"
    fi

    # ---- APP_KEY ------------------------------------------------------------
    local current_key
    current_key=$(grep -E '^APP_KEY=' "${PROJECT_ROOT}/.env" | head -n1 | cut -d= -f2- | tr -d '"' || true)
    if [[ -z "$current_key" || "$current_key" == "base64:" ]]; then
        print_info "Generating APP_KEY..."
        local new_key="base64:$(openssl rand -base64 32)"
        if grep -qE '^APP_KEY=' "${PROJECT_ROOT}/.env"; then
            if [[ "$(uname)" == "Darwin" ]]; then
                sed -i '' "s|^APP_KEY=.*|APP_KEY=${new_key}|" "${PROJECT_ROOT}/.env"
            else
                sed -i "s|^APP_KEY=.*|APP_KEY=${new_key}|" "${PROJECT_ROOT}/.env"
            fi
        else
            echo "APP_KEY=${new_key}" >> "${PROJECT_ROOT}/.env"
        fi
        print_success "APP_KEY set"
    fi

    # ---- Perms --------------------------------------------------------------
    chmod +x "${PROJECT_ROOT}/dock" 2>/dev/null || true
    find "${PROJECT_ROOT}/scripts" -type f -name '*.sh' -exec chmod +x {} \; 2>/dev/null || true
    chmod 600 "${PROJECT_ROOT}/.env"

    # Storage must be writable by the app container (laravel UID/GID).
    # DB data dir is NOT touched - the mariadb image's entrypoint manages its
    # own ownership (mysql user inside the container, usually UID 999).
    if chown -R "${host_uid}:${host_gid}" "$storage_path" 2>/dev/null; then
        chmod -R 775 "$storage_path" 2>/dev/null || true
    else
        print_warning "chown of storage skipped (owned by another user)."
        print_info "    If the app fails with 'Permission denied' on storage, run once:"
        print_info "    sudo chown -R ${host_uid}:${host_gid} ${storage_path}"
    fi

    # Make sure db data dir exists but DON'T chown it - that's mariadb's job.
    mkdir -p "$db_path" 2>/dev/null || true

    # ---- Build + start ------------------------------------------------------
    local dock_args=("--build")
    [[ "$VERBOSE" == "true" ]] && dock_args+=("--verbose")
    [[ "$QUIET" == "true" ]] && dock_args+=("--quiet")
    [[ "$DEBUG" == "true" ]] && dock_args+=("--debug")

    print_info "Building and starting containers..."
    "${PROJECT_ROOT}/dock" start "${dock_args[@]}" || { print_error "Container start failed"; return 1; }

    # ---- Post-deploy --------------------------------------------------------
    print_section "${ICON_GEAR} Post-deploy"

    print_info "Waiting for database..."
    local waited=0
    while ! docker exec "${CONTAINER_NAME}-mariadb" healthcheck.sh --connect &>/dev/null; do
        waited=$((waited + 1))
        if (( waited > 60 )); then
            print_error "Database did not become ready in 60s"
            return 1
        fi
        sleep 1
    done
    print_success "Database ready"

    print_info "Running migrations..."
    docker exec "${CONTAINER_NAME}" php artisan migrate --force || \
        print_warning "Migration failed - check logs"

    print_info "Storage link..."
    docker exec "${CONTAINER_NAME}" php artisan storage:link --force 2>/dev/null || true

    print_info "Rebuilding caches..."
    docker exec "${CONTAINER_NAME}" php artisan config:cache 2>/dev/null || true
    docker exec "${CONTAINER_NAME}" php artisan route:cache 2>/dev/null || true
    docker exec "${CONTAINER_NAME}" php artisan view:cache 2>/dev/null || true
    docker exec "${CONTAINER_NAME}" php artisan event:cache 2>/dev/null || true

    if [[ "${SERVER:-artisan}" == "octane" ]]; then
        docker exec "${CONTAINER_NAME}" php artisan octane:reload 2>/dev/null || true
    fi

    print_success "Deployment complete!"
    print_ready "http://${DOMAIN:-localhost}:${APP_PORT:-8000}"
}

# -----------------------------------------------------------------------------
# Command: install
# -----------------------------------------------------------------------------
cmd_install() {
    print_header "Install Dockerized Laravel"
    
    # Source the configure script functionality
    if [[ -f "${PROJECT_ROOT}/configure-app.sh" ]]; then
        bash "${PROJECT_ROOT}/configure-app.sh"
    else
        print_error "Installation script not found"
        return 1
    fi
}

# -----------------------------------------------------------------------------
# Main Argument Parsing
# -----------------------------------------------------------------------------
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -q|--quiet)
                QUIET=true
                shift
                ;;
            --debug)
                DEBUG=true
                VERBOSE=true
                shift
                ;;
            -e|--env)
                ENV_FILE="$2"
                shift 2
                ;;
            -h|--help)
                if [[ -n "$COMMAND" ]]; then
                    show_command_help "$COMMAND"
                else
                    show_help
                fi
                exit 0
                ;;
            -V|--version|version)
                echo "dock v${VERSION}"
                exit 0
                ;;
            -*)
                # Unknown option, pass to command
                ARGS+=("$1")
                shift
                ;;
            *)
                if [[ -z "$COMMAND" ]]; then
                    COMMAND="$1"
                else
                    ARGS+=("$1")
                fi
                shift
                ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
main() {
    parse_args "$@"
    
    # Export globals for library functions
    export VERBOSE QUIET DEBUG
    
    # Default to help if no command
    if [[ -z "$COMMAND" ]]; then
        show_help
        exit 0
    fi
    
    # Change to project root
    cd "$PROJECT_ROOT" || exit 1
    
    # Dispatch command
    case "$COMMAND" in
        start)    cmd_start "${ARGS[@]}" ;;
        stop)     cmd_stop "${ARGS[@]}" ;;
        restart)  cmd_restart "${ARGS[@]}" ;;
        status)   cmd_status "${ARGS[@]}" ;;
        logs)     cmd_logs "${ARGS[@]}" ;;
        shell|sh) cmd_shell "${ARGS[@]}" ;;
        exec)     cmd_exec "${ARGS[@]}" ;;
        artisan)  cmd_artisan "${ARGS[@]}" ;;
        composer) cmd_composer "${ARGS[@]}" ;;
        npm)      cmd_npm "${ARGS[@]}" ;;
        tinker)   cmd_tinker "${ARGS[@]}" ;;
        migrate)  cmd_migrate "${ARGS[@]}" ;;
        fresh)    cmd_fresh "${ARGS[@]}" ;;
        seed)     cmd_seed "${ARGS[@]}" ;;
        deploy)   cmd_deploy "${ARGS[@]}" ;;
        install)  cmd_install "${ARGS[@]}" ;;
        help)     show_help ;;
        *)
            print_error "Unknown command: ${COMMAND}"
            print_info "Run './dock help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
