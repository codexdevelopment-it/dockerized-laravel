show_command_help() {
    local cmd="$1"
    
    case "$cmd" in
        start)
            echo ""
            echo -e "${BOLD}dock start${NC} - Start application containers"
            echo ""
            echo -e "${BOLD}USAGE${NC}"
            echo "    ./dock start [options]"
            echo ""
            echo -e "${BOLD}OPTIONS${NC}"
            echo "    --build         Force rebuild containers"
            echo "    --no-cache      Build without using cache"
            echo "    -v, --verbose   Show detailed output"
            echo "    -q, --quiet     Suppress output"
            echo ""
            echo -e "${BOLD}DESCRIPTION${NC}"
            echo "    Starts all configured containers based on your .env settings."
            echo "    Automatically handles Octane setup if SERVER=octane."
            echo ""
            ;;
        stop)
            echo ""
            echo -e "${BOLD}dock stop${NC} - Stop application containers"
            echo ""
            echo -e "${BOLD}USAGE${NC}"
            echo "    ./dock stop [options]"
            echo ""
            echo -e "${BOLD}OPTIONS${NC}"
            echo "    -v, --verbose   Show detailed output"
            echo "    -q, --quiet     Suppress output"
            echo ""
            echo -e "${BOLD}DESCRIPTION${NC}"
            echo "    Stops and removes all containers for the current project."
            echo "    Volumes are preserved by default."
            echo ""
            ;;
        logs)
            echo ""
            echo -e "${BOLD}dock logs${NC} - View container logs"
            echo ""
            echo -e "${BOLD}USAGE${NC}"
            echo "    ./dock logs [service] [options]"
            echo ""
            echo -e "${BOLD}OPTIONS${NC}"
            echo "    -f, --follow    Follow log output"
            echo "    -n, --tail <N>  Number of lines to show (default: 100)"
            echo ""
            echo -e "${BOLD}EXAMPLES${NC}"
            echo "    ./dock logs              # All container logs"
            echo "    ./dock logs app          # Only app container"
            echo "    ./dock logs -f           # Follow all logs"
            echo "    ./dock logs app -f -n 50 # Follow app logs, last 50 lines"
            echo ""
            ;;
        deploy)
            echo ""
            echo -e "${BOLD}dock deploy${NC} - Deploy / re-deploy this checkout"
            echo ""
            echo -e "${BOLD}USAGE${NC}"
            echo "    ./dock deploy [options]"
            echo ""
            echo -e "${BOLD}OPTIONS${NC}"
            echo "    -y, --yes        Skip the confirmation prompt"
            echo "    --skip-pull      Don't fetch/pull from origin (use current checkout as-is)"
            echo ""
            echo -e "${BOLD}DESCRIPTION${NC}"
            echo "    Runs from inside a cloned repo with a populated .env. The script will:"
            echo "      1. git fetch origin and show the commits being deployed"
            echo "      2. ask for confirmation"
            echo "      3. git pull (rebase + autostash)"
            echo "      4. generate APP_KEY if missing, persist USER_ID/GROUP_ID"
            echo "      5. build + start containers"
            echo "      6. run migrations and rebuild caches"
            echo ""
            echo -e "${BOLD}FIRST-TIME SETUP${NC}"
            echo "    1. ssh into the server"
            echo "    2. git clone <your-app-repo> /var/www/myapp && cd /var/www/myapp"
            echo "    3. copy/edit .env (set APP_ENV=production, CONTAINER_NAME, DB_*, DOMAIN)"
            echo "    4. ./dock deploy"
            echo ""
            echo -e "${BOLD}RE-DEPLOY${NC}"
            echo "    cd /var/www/myapp && ./dock deploy"
            echo ""
            ;;
        *)
            show_help
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Command: start
# -----------------------------------------------------------------------------
cmd_start() {
    local build=false
    local no_cache=false
    
    # Parse command-specific options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --build)    build=true; shift ;;
            --no-cache) no_cache=true; shift ;;
            -h|--help)  show_command_help start; return 0 ;;
            *)          shift ;;
        esac
    done
    
    print_header "Dockerized Laravel"
    
    # Load and validate environment
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    validate_full_env "start" || return 1
    
    # Run pre-flight checks
    run_preflight_checks "start" "$PROJECT_ROOT" || return 1
    
    # Print configuration
    print_env_summary
    
    # Start containers
    print_section "${ICON_PACKAGE} Starting Containers"
    
    # Always stream docker output — builds can take minutes and a silent
    # spinner looks frozen. -q suppresses dock's own chatter, not docker's.
    local exit_code=0
    print_info "Starting containers..."
    docker_up "$build" || exit_code=$?
    
    if [[ $exit_code -ne 0 ]]; then
        print_error "Failed to start containers"
        return 1
    fi
    
    print_success "Containers started"
    
    # Give containers a moment to initialize
    sleep 2
    
    # Print status (ignore errors - containers might not be labeled yet)
    print_container_status || true
    
    # Octane setup only when actually using Octane.
    # nginx/caddy talk FastCGI to php-fpm on app:9000 - no octane needed.
    if [[ "${SERVER:-artisan}" == "octane" ]]; then
        setup_octane || true
    fi
    
    # Standard provisioning
    provision_app || true
    
    # Handle artisan serve mode (interactive)
    if [[ "${SERVER:-artisan}" == "artisan" ]]; then
        print_ready "http://localhost:${APP_PORT:-8000}"
        print_info "Starting artisan serve (Ctrl+C to stop)..."
        docker exec -it "${CONTAINER_NAME}" php artisan serve --host=0.0.0.0 --port=80
    else
        print_ready "http://localhost:${APP_PORT:-8000}"
    fi

    return 0
}

# Setup Octane server.
# All steps are best-effort: a failure here must NOT kill the deploy if the
# containers are otherwise running. Add laravel/octane to composer.json of the
# app to avoid the runtime install path entirely.
setup_octane() {
    print_verbose "Setting up Octane..."

    if ! check_octane_installed; then
        print_warning "laravel/octane not found in image - installing at runtime (slow + lost on rebuild)"
        print_info "Fix: add 'laravel/octane' to composer.json and redeploy"
        docker exec "${CONTAINER_NAME}" composer require laravel/octane 2>/dev/null || true
        docker exec "${CONTAINER_NAME}" php artisan octane:install --server=frankenphp -q 2>/dev/null || true
    fi

    print_verbose "Linking FrankenPHP binary..."
    docker exec "${CONTAINER_NAME}" mkdir -p vendor/laravel/octane/bin 2>/dev/null || true
    docker exec "${CONTAINER_NAME}" ln -sf /usr/local/bin/frankenphp vendor/laravel/octane/bin/frankenphp-linux-x86_64 2>/dev/null || true
    docker exec "${CONTAINER_NAME}" ln -sf /usr/local/bin/frankenphp vendor/laravel/octane/bin/frankenphp-linux-aarch64 2>/dev/null || true

    docker exec "${CONTAINER_NAME}" supervisorctl -c /etc/supervisor/conf.d/00-base.conf restart octane 2>/dev/null || true
    return 0
}

# Provision the application.
# Runs `docker exec` steps that may legitimately fail (missing artisan, perms);
# always returns 0 so callers don't blow up. In verbose mode, errors print.
provision_app() {
    print_verbose "Provisioning application..."

    # Helper: run docker exec and report failures only in verbose mode
    _provision_run() {
        local label="$1"; shift
        if [[ "${VERBOSE:-false}" == "true" ]]; then
            docker exec "${CONTAINER_NAME}" "$@" || \
                print_warning "  ${label} returned non-zero (continuing)"
        else
            docker exec "${CONTAINER_NAME}" "$@" >/dev/null 2>&1 || true
        fi
    }

    # Storage scaffolding (in case the image was built without these dirs).
    _provision_run "mkdir storage" sh -c 'mkdir -p storage/framework/{sessions,views,cache} storage/app/public storage/logs bootstrap/cache'
    _provision_run "chmod storage" sh -c 'chmod -R 775 storage bootstrap/cache 2>/dev/null'
    _provision_run "chown storage" sh -c 'chown -R laravel:www-data storage bootstrap/cache 2>/dev/null'
    _provision_run "setfacl storage" setfacl -R -d -m u::rwX,g::rwX,o::rX storage/app/public/
    _provision_run "setfacl public" setfacl -R -d -m u::rwX,g::rwX,o::rX public/

    # Generate key only in local (.env is writable). Prod handles this in deploy.
    if is_local_env && [[ -z "${APP_KEY:-}" ]]; then
        print_verbose "Generating application key..."
        _provision_run "key:generate" php artisan key:generate
    fi

    _provision_run "storage:link" php artisan storage:link --force

    if is_local_env; then
        print_verbose "Clearing caches for local development..."
        _provision_run "optimize:clear" php artisan optimize:clear
    fi

    return 0
}

# -----------------------------------------------------------------------------
# Command: stop
# -----------------------------------------------------------------------------
cmd_stop() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help) show_command_help stop; return 0 ;;
            *) shift ;;
        esac
    done
    
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    
    print_info "Stopping containers..."
    docker_down || true
    print_success "Containers stopped"
}

# -----------------------------------------------------------------------------
# Command: restart
# -----------------------------------------------------------------------------
cmd_restart() {
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    
    print_info "Restarting containers..."
    docker_restart || true
    print_success "Containers restarted"
}

# -----------------------------------------------------------------------------
# Command: status
# -----------------------------------------------------------------------------
cmd_status() {
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    
    print_header "Container Status"
    print_container_status
    
    print_nl
    print_section "${ICON_INFO} Details"
    docker_status
}

# -----------------------------------------------------------------------------
# Command: logs
# -----------------------------------------------------------------------------
cmd_logs() {
    local service=""
    local follow=false
    local tail=100
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--follow) follow=true; shift ;;
            -n|--tail)   tail="$2"; shift 2 ;;
            -h|--help)   show_command_help logs; return 0 ;;
            -*)          shift ;;
            *)           service="$1"; shift ;;
        esac
    done
    
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    docker_logs "$service" "$follow" "$tail"
}

# -----------------------------------------------------------------------------
# Command: shell
# -----------------------------------------------------------------------------
cmd_shell() {
    load_env "${PROJECT_ROOT}/${ENV_FILE}" || return 1
    
    local container="${1:-${CONTAINER_NAME}}"
    
    # Handle container name shortcuts
    if [[ -n "$1" ]] && [[ "$1" != "${CONTAINER_NAME}" ]] && [[ "$1" != "${CONTAINER_NAME}-"* ]]; then
        container="${CONTAINER_NAME}-${1}"
    fi
    
    print_info "Opening shell in ${container}..."
    docker exec -it "$container" bash || docker exec -it "$container" sh
}

