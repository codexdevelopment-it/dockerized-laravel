# =============================================================================
# Dockerized Laravel Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="{{APP_NAME}}"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL="http://localhost:8000"
APP_PORT=8000

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
# Container base name (e.g., 'myapp' creates 'myapp', 'myapp-mariadb', etc.)
CONTAINER_NAME="{{CONTAINER_NAME}}"

# Server type: artisan, octane, fpm, nginx, caddy
SERVER=artisan

# Additional services (comma-separated): redis,mailpit,meilisearch,phpmyadmin
SERVICES=

# -----------------------------------------------------------------------------
# Deployment (Production)
# -----------------------------------------------------------------------------
REPO_URL={{REPO_URL}}
BRANCH=main
DEPLOY_DIR=

# Storage mount paths (production only)
STORAGE_MOUNT_PATH=./storage
DB_MOUNT_PATH=./db-data

# -----------------------------------------------------------------------------
# Localization
# -----------------------------------------------------------------------------
APP_TIMEZONE=Europe/Rome
APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE="{{DB_NAME}}"
DB_USERNAME=app
DB_PASSWORD=password

# -----------------------------------------------------------------------------
# Cache & Session
# -----------------------------------------------------------------------------
CACHE_DRIVER=file
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# -----------------------------------------------------------------------------
# Queue
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=sync

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=daily
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail (Mailpit for local development)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Vite / Frontend
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
