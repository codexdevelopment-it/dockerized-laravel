# =============================================================================
# Caddy + PHP-FPM
# Automatic HTTPS (Let's Encrypt) when DOMAIN is a real public domain.
# =============================================================================

{$DOMAIN:localhost} {
    root * /var/www/html/public
    encode gzip zstd

    php_fastcgi app:9000

    file_server

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        -Server
    }

    log {
        output stdout
        format console
    }
}
